# Server
METEORX_APP_PORT=8081
METEORX_APP_MODE=debug

# Database
METEORX_DB_HOST=127.0.0.1
METEORX_DB_PORT=3306
METEORX_DB_USER=root
METEORX_DB_PASSWORD=123456
METEORX_DB_NAME=meteorx
METEORX_DB_TLS=false

# Redis
METEORX_REDIS_HOST=localhost
METEORX_REDIS_PORT=6379
METEORX_REDIS_PASSWORD=""
METEORX_REDIS_DB=0

# JWT
METEORX_JWT_SECRET=your-secret-key
METEORX_JWT_EXPIRATION=24h
METEORX_JWT_ISSUER=meteorx-auth
